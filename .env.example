# Postgres — required for cumulative playoff leaderboard + ingest.
#
# Local (after `docker compose up -d`):
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/realtime_api
#
# Staging / production: create a database on your host (e.g. Neon, Supabase, RDS)
# and paste its connection string here or in the host’s env UI.
#
# Vercel Postgres / Storage often sets POSTGRES_URL (and optionally
# POSTGRES_URL_NON_POOLING for migrations). This app reads DATABASE_URL or POSTGRES_URL.
#
# Optional: canonical origin for shared-link previews (Open Graph). No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
DATABASE_URL=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# First calendar day included in cumulative playoff scoring (YYYY-MM-DD).
POOL_PLAYOFF_START_DATE=2026-04-18

# Optional: last N playoff calendar days always re-fetch NHL scoreboards for round-window cache (default 2).
# POOL_SCOREBOARD_CACHE_TAIL_DAYS=2

# IANA timezone for “today” in standings / day-sources (default America/Los_Angeles).
# Set on Vercel so server date matches Pacific evening, not UTC midnight.
# NEXT_PUBLIC_POOL_CALENDAR_TIMEZONE=America/Los_Angeles
# POOL_CALENDAR_TIMEZONE=America/Los_Angeles

# Temporary local UI test override: force teams to show as eliminated everywhere.
# Comma-separated NHL abbreviations, e.g. "EDM,DAL". Leave blank to disable.
# POOL_TEST_ELIMINATED_TEAMS=

# Shared secret for secured ingest routes (Authorization: Bearer …):
# - GET  /api/pool/internal/cron-ingest-yesterday
# - GET/POST /api/pool/internal/reingest            (manual; GET = yesterday, POST = same body as ingest-daily)
# - POST /api/pool/internal/ingest-daily
#
# If set to true or 1, those routes accept requests **without** Bearer (URL is a write — use only with
# deployment protection / private access). Leave unset or false in public production otherwise.
# ALLOW_UNAUTHENTICATED_POOL_INGEST=
CRON_SECRET=
